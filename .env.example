# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin credentials (MVP)
ADMIN_EMAIL=admin@imobiliaria.com
ADMIN_PASSWORD=senha_segura_aqui

# Auth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-here

# Groq (LLM para Triagem/Intenção)
GROQ_API_KEY=gsk_your_groq_api_key

# Evolution API (WhatsApp Provider)
EVOLUTION_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-apikey-global

# Vercel Cron
CRON_SECRET=your-secure-cron-secret

# Alertas (Opcional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000...
